<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F4F5">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270" MinWidth="150" MaxWidth="560"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── SPLITTER ──────────────────────────────────── -->
        <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"
                      Background="#E4E4E7" Cursor="SizeWE"/>

        <!-- ── LEFT PANE ──────────────────────────────── -->
        <Border Name="LeftPanel" Grid.Column="0" Background="White"
                BorderBrush="#E4E4E7" BorderThickness="0,0,0,0">
            <DockPanel LastChildFill="True">

                <!-- ── Top section: buttons + stats ─── -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,0">

                    <TextBlock Text="GPX FILE"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="#A1A1AA" Margin="0,0,0,10"/>

                    <Button Name="BtnLoad" Content="Load GPX…"
                            Height="34" Margin="0,0,0,6"
                            Background="#18181B" Foreground="White"
                            FontSize="13" FontWeight="Medium"
                            BorderThickness="0"/>

                    <Button Name="BtnSave" Content="Save GPX…"
                            Height="34" Margin="0,0,0,14"
                            Background="#2563EB" Foreground="White"
                            FontSize="13" FontWeight="Medium"
                            BorderThickness="0"
                            IsEnabled="False"/>

                    <Separator Background="#E4E4E7" Margin="0,0,0,14"/>

                    <TextBlock Text="TRACK INFO"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="#A1A1AA" Margin="0,0,0,10"/>

                    <TextBlock Name="LblTrackName"
                               Text="—"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#18181B"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,10">
                            <TextBlock Text="Distance" FontSize="10" Foreground="#A1A1AA" Margin="0,0,0,2"/>
                            <TextBlock Name="LblDistance" Text="—" FontSize="13" FontWeight="Medium" Foreground="#18181B"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                            <TextBlock Text="Points" FontSize="10" Foreground="#A1A1AA" Margin="0,0,0,2"/>
                            <TextBlock Name="LblPoints" Text="—" FontSize="13" FontWeight="Medium" Foreground="#18181B"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,10">
                            <TextBlock Text="Ele. gain" FontSize="10" Foreground="#A1A1AA" Margin="0,0,0,2"/>
                            <TextBlock Name="LblEleGain" Text="—" FontSize="13" FontWeight="Medium" Foreground="#22C55E"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                            <TextBlock Text="Ele. loss" FontSize="10" Foreground="#A1A1AA" Margin="0,0,0,2"/>
                            <TextBlock Name="LblEleLoss" Text="—" FontSize="13" FontWeight="Medium" Foreground="#EF4444"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,10">
                            <TextBlock Text="Ele. min" FontSize="10" Foreground="#A1A1AA" Margin="0,0,0,2"/>
                            <TextBlock Name="LblEleMin" Text="—" FontSize="13" FontWeight="Medium" Foreground="#18181B"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                            <TextBlock Text="Ele. max" FontSize="10" Foreground="#A1A1AA" Margin="0,0,0,2"/>
                            <TextBlock Name="LblEleMax" Text="—" FontSize="13" FontWeight="Medium" Foreground="#18181B"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,10">
                            <TextBlock Text="Duration" FontSize="10" Foreground="#A1A1AA" Margin="0,0,0,2"/>
                            <TextBlock Name="LblDuration" Text="—" FontSize="13" FontWeight="Medium" Foreground="#18181B"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="#E4E4E7" Margin="0,2,0,0"/>

                </StackPanel>

                <!-- ── File tree header ───────────────── -->
                <Border DockPanel.Dock="Top"
                        Background="#F9F9F9"
                        BorderBrush="#E4E4E7" BorderThickness="0,0,0,1"
                        Padding="16,7">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="LOADED FILES"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#A1A1AA"
                                   VerticalAlignment="Center"/>
                        <TextBlock Name="LblStatus"
                                   Grid.Column="1"
                                   Text="No file loaded"
                                   FontSize="10" Foreground="#A1A1AA"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ── File tree (fills remaining height) -->
                <TreeView Name="FileTree"
                          BorderThickness="0"
                          Background="White"
                          FontSize="12"
                          Padding="4,4,4,4">
                    <TreeView.Resources>
                        <!-- Neutral selection highlight: light blue bg so any text colour is readable -->
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                         Color="#DBEAFE"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                         Color="#DBEAFE"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                                         Color="#1E40AF"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
                                         Color="#1E40AF"/>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Padding" Value="3,4"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </TreeView.Resources>
                </TreeView>

            </DockPanel>
        </Border>

        <!-- ── MAP ──────────────────────────────────────── -->
        <WebBrowser Name="MapBrowser" Grid.Column="2"/>

    </Grid>
</Page>
