<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F4F5">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── LEFT PANE ──────────────────────────────── -->
        <Border Name="LeftPanel" Grid.Column="0" Background="White"
                BorderBrush="#E4E4E7" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">

                <!-- ── Top controls ───────────────────── -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,0">

                    <!-- Profile label -->
                    <TextBlock Text="ROUTING PROFILE"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="#A1A1AA" Margin="0,0,0,10"/>

                    <!-- Profile selector pills -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Name="BtnFoot" Grid.Column="0"
                                CornerRadius="6" Padding="0,7"
                                Background="#18181B" Cursor="Hand">
                            <TextBlock Name="BtnFootTxt" Text="🚶 Foot"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                        </Border>

                        <Border Name="BtnBike" Grid.Column="2"
                                CornerRadius="6" Padding="0,7"
                                Background="Transparent"
                                BorderBrush="#E4E4E7" BorderThickness="1"
                                Cursor="Hand">
                            <TextBlock Name="BtnBikeTxt" Text="🚴 Bike"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="#71717A"
                                       HorizontalAlignment="Center"/>
                        </Border>

                        <Border Name="BtnCar" Grid.Column="4"
                                CornerRadius="6" Padding="0,7"
                                Background="Transparent"
                                BorderBrush="#E4E4E7" BorderThickness="1"
                                Cursor="Hand">
                            <TextBlock Name="BtnCarTxt" Text="🚗 Car"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="#71717A"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Name="BtnDirect" Grid.Column="0"
                                CornerRadius="6" Padding="0,7"
                                Background="Transparent"
                                BorderBrush="#E4E4E7" BorderThickness="1"
                                Cursor="Hand">
                            <TextBlock Name="BtnDirectTxt" Text="⟶ Direct"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="#71717A"
                                       HorizontalAlignment="Center"/>
                        </Border>

                        <Border Name="BtnDraw" Grid.Column="2"
                                CornerRadius="6" Padding="0,7"
                                Background="Transparent"
                                BorderBrush="#E4E4E7" BorderThickness="1"
                                Cursor="Hand">
                            <TextBlock Name="BtnDrawTxt" Text="✏ Draw"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="#71717A"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- Action buttons -->
                    <Button Name="BtnClear" Content="Clear Route"
                            Height="34" Margin="0,0,0,6"
                            Background="#F4F4F5" Foreground="#18181B"
                            FontSize="12" FontWeight="Medium"
                            BorderBrush="#E4E4E7" BorderThickness="1"/>

                    <Button Name="BtnExport" Content="Export GPX…"
                            Height="34" Margin="0,0,0,14"
                            Background="#2563EB" Foreground="White"
                            FontSize="12" FontWeight="Medium"
                            BorderThickness="0"
                            IsEnabled="False"/>

                    <Separator Background="#E4E4E7" Margin="0,0,0,14"/>

                    <!-- Route stats -->
                    <TextBlock Text="ROUTE STATS"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="#A1A1AA" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Distance" FontSize="10" Foreground="#A1A1AA" Margin="0,0,0,2"/>
                            <TextBlock Name="LblDistance" Text="—" FontSize="14" FontWeight="Medium" Foreground="#18181B"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Est. time" FontSize="10" Foreground="#A1A1AA" Margin="0,0,0,2"/>
                            <TextBlock Name="LblDuration" Text="—" FontSize="14" FontWeight="Medium" Foreground="#18181B"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="#E4E4E7" Margin="0,0,0,0"/>
                </StackPanel>

                <!-- ── Waypoints header ────────────────── -->
                <Border DockPanel.Dock="Top"
                        Background="#F9F9F9"
                        BorderBrush="#E4E4E7" BorderThickness="0,0,0,1"
                        Padding="16,7">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="WAYPOINTS"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#A1A1AA" VerticalAlignment="Center"/>
                        <TextBlock Name="LblWptCount" Grid.Column="1"
                                   Text="0 points"
                                   FontSize="10" Foreground="#A1A1AA"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ── Waypoints list (fills remaining height) -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Name="WptStack" Margin="8,6,8,6"/>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- ── MAP ──────────────────────────────────────── -->
        <WebBrowser Name="MapBrowser" Grid.Column="1"/>

    </Grid>
</Page>
