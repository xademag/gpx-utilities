<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F4F5">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" MinWidth="140" MaxWidth="400"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── LEFT: track tree ────────────────────────────── -->
        <Border Grid.Column="0" Background="White"
                BorderBrush="#E4E4E7" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">

                <Border DockPanel.Dock="Top"
                        Background="#F9F9F9"
                        BorderBrush="#E4E4E7" BorderThickness="0,0,0,1"
                        Padding="14,8">
                    <TextBlock Text="TRACKS"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="#A1A1AA"/>
                </Border>

                <TreeView Name="VideoFileTree"
                          BorderThickness="0"
                          Background="White"
                          FontSize="12"
                          Padding="4,4,4,4">
                    <TreeView.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                         Color="#DBEAFE"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                         Color="#DBEAFE"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                                         Color="#1E40AF"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
                                         Color="#1E40AF"/>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Padding" Value="3,4"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </TreeView.Resources>
                </TreeView>

            </DockPanel>
        </Border>

        <!-- ── SPLITTER ────────────────────────────────────── -->
        <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"
                      Background="#E4E4E7" Cursor="SizeWE"/>

        <!-- ── RIGHT: video + timeline ─────────────────────── -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="190" MinHeight="100"/>
            </Grid.RowDefinitions>

            <!-- VIDEO AREA -->
            <Grid Grid.Row="0" Name="VideoArea" Background="#0A0A0A" ClipToBounds="True">

                <MediaElement Name="VideoPlayer"
                              LoadedBehavior="Manual"
                              ScrubbingEnabled="True"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>

                <!-- Placeholder when no video loaded -->
                <TextBlock Name="TxtNoVideo"
                           Text="Open a video file to begin"
                           Foreground="#3F3F46" FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- Text overlays canvas — Transparent so empty areas pass clicks through -->
                <Canvas Name="OverlayCanvas"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Background="Transparent"/>

                <!-- Overlay edit bar — shown when an overlay is selected -->
                <Border Name="OverlayEditBar" VerticalAlignment="Top"
                        Background="#CC18181B" Padding="10,6"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Text:" Foreground="#A1A1AA"
                                   FontSize="11" VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBox Name="OverlayTextBox" Grid.Column="1"
                                 Background="#22FFFFFF" Foreground="White"
                                 BorderBrush="#52525B" BorderThickness="1"
                                 Padding="4,2" FontSize="12" Height="26"
                                 VerticalContentAlignment="Center"
                                 CaretBrush="White"/>
                        <Border Name="BtnApplyOverlayText" Grid.Column="2"
                                CornerRadius="3" Padding="10,0" Height="26"
                                Background="#2563EB" Cursor="Hand" Margin="6,0,0,0">
                            <TextBlock Text="Apply" Foreground="White" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <Border Name="BtnDeleteOverlay" Grid.Column="3"
                                CornerRadius="3" Width="26" Height="26"
                                Background="#DC2626" Cursor="Hand" Margin="4,0,0,0">
                            <TextBlock Text="✕" Foreground="White" FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Bottom toolbar overlay -->
                <Border VerticalAlignment="Bottom"
                        Background="#CC0A0A0A" Padding="10,7">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Playback controls -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <Border Name="BtnGoStart" Width="32" Height="28" CornerRadius="4"
                                    Background="#1FFFFFFF" Cursor="Hand" Margin="0,0,3,0">
                                <TextBlock Text="⏮" Foreground="White" FontSize="12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Name="BtnPrevFrame" Width="32" Height="28" CornerRadius="4"
                                    Background="#1FFFFFFF" Cursor="Hand" Margin="0,0,3,0">
                                <TextBlock Text="◀◀" Foreground="White" FontSize="10"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Name="BtnRewind" Width="38" Height="28" CornerRadius="4"
                                    Background="#1FFFFFFF" Cursor="Hand" Margin="0,0,3,0">
                                <TextBlock Text="−5s" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Name="BtnPlayPause" Width="40" Height="28" CornerRadius="4"
                                    Background="#2563EB" Cursor="Hand" Margin="0,0,3,0">
                                <TextBlock Name="TxtPlayPause" Text="▶"
                                           Foreground="White" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Name="BtnFwd" Width="38" Height="28" CornerRadius="4"
                                    Background="#1FFFFFFF" Cursor="Hand" Margin="0,0,3,0">
                                <TextBlock Text="+5s" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Name="BtnNextFrame" Width="32" Height="28" CornerRadius="4"
                                    Background="#1FFFFFFF" Cursor="Hand" Margin="0,0,3,0">
                                <TextBlock Text="▶▶" Foreground="White" FontSize="10"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Name="BtnGoEnd" Width="32" Height="28" CornerRadius="4"
                                    Background="#1FFFFFFF" Cursor="Hand" Margin="0,0,0,0">
                                <TextBlock Text="⏭" Foreground="White" FontSize="12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                        </StackPanel>

                        <!-- Time display + FPS -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Name="LblVideoTime" Text="0:00.000"
                                       Foreground="White" FontSize="12"
                                       FontFamily="Consolas" VerticalAlignment="Center"/>
                            <TextBlock Text=" / " Foreground="#71717A" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBlock Name="LblVideoDuration" Text="0:00.000"
                                       Foreground="#A1A1AA" FontSize="12"
                                       FontFamily="Consolas" VerticalAlignment="Center"/>
                            <TextBlock Text="FPS" Foreground="#71717A" FontSize="10"
                                       VerticalAlignment="Center" Margin="16,0,4,0"/>
                            <TextBox Name="TxtFPS" Text="30" Width="36" Height="22"
                                     FontSize="11" TextAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="#52525B" BorderThickness="1"
                                     Background="Transparent" Foreground="White"
                                     CaretBrush="White"/>
                        </StackPanel>

                        <!-- Map toggle + Add overlay + Open video -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Name="BtnToggleMap" Width="30" Height="28" CornerRadius="4"
                                    Background="#1FFFFFFF" Cursor="Hand" Margin="0,0,6,0">
                                <TextBlock Text="🗺" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Name="BtnAddOverlay" Width="36" Height="28" CornerRadius="4"
                                    Background="#1FFFFFFF" Cursor="Hand" Margin="0,0,6,0">
                                <TextBlock Text="T+" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Name="BtnOpenVideo" CornerRadius="4" Padding="10,0"
                                    Height="28" Background="#18181B" Cursor="Hand">
                                <TextBlock Text="Open Video…" Foreground="White" FontSize="11"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>

                    </Grid>
                </Border>
            </Grid>

            <!-- ROW SPLITTER -->
            <GridSplitter Grid.Row="1"
                          Height="5"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          Background="#E4E4E7" Cursor="SizeNS"/>

            <!-- TIMELINE PANEL -->
            <Grid Grid.Row="2" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Track info row -->
                <Border Grid.Row="0"
                        Background="#F9F9F9"
                        BorderBrush="#E4E4E7" BorderThickness="0,0,0,1"
                        Padding="12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Name="LblSyncStatus" Text="Select a track"
                                   FontSize="11" Foreground="#71717A"
                                   VerticalAlignment="Center"/>
                        <Border Name="BtnSnap" Grid.Column="1"
                                CornerRadius="3" Padding="8,0" Height="22"
                                Background="#E4E4E7" Cursor="Hand" Margin="0,0,4,0">
                            <TextBlock Name="TxtSnapLabel" Text="⊠ Snap ON"
                                       FontSize="10" Foreground="#52525B"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Timeline canvas -->
                <Canvas Name="TimelineCanvas" Grid.Row="1"
                        Background="#F8F8F8" ClipToBounds="True"
                        Cursor="Hand"/>

            </Grid>

        </Grid>

        <!-- ── Map overlay popup ──────────────────────────────────────────── -->
         <Popup Name="MapOverlayPopup"
             Grid.Column="2"
             AllowsTransparency="False" StaysOpen="True"
             Placement="Absolute">

            <Border BorderBrush="#3F3F46" BorderThickness="1"
                    CornerRadius="6" ClipToBounds="True" Width="290">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="3" BlurRadius="10"
                                      Color="#000000" Opacity="0.5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="210"/>
                    </Grid.RowDefinitions>

                    <!-- Drag handle -->
                    <Border Name="MapDragHandle" Grid.Row="0"
                            Background="#18181B" Cursor="SizeAll">
                        <Grid Margin="10,0,4,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Map"
                                       Foreground="#A1A1AA" FontSize="11"
                                       VerticalAlignment="Center"/>
                            <Border Name="BtnCloseMap" Grid.Column="1"
                                    Width="22" Height="22" CornerRadius="4"
                                    Background="Transparent" Cursor="Hand"
                                    VerticalAlignment="Center" Margin="0,2">
                                <TextBlock Text="×" Foreground="#71717A"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Leaflet map -->
                    <WebBrowser Name="MapOverlayBrowser"
                                Grid.Row="1" Width="290" Height="210"/>
                </Grid>
            </Border>

        </Popup>

    </Grid>
</Page>
