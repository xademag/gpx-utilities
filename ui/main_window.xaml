<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GPX Utility"
        Height="860" Width="1440"
        Background="#F4F4F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Top Banner ─────────────────────────────────── -->
        <Border Grid.Row="0" Background="#18181B">
            <DockPanel VerticalAlignment="Stretch" LastChildFill="True" Margin="20,0">

                <!-- App title -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="GPX Utility"
                               Foreground="#FAFAFA"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Border Background="#27272A" CornerRadius="4"
                            Padding="6,2" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="v1.0" Foreground="#71717A" FontSize="11"/>
                    </Border>
                </StackPanel>

                <!-- Tab pills -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <Border Name="BtnMap" CornerRadius="5" Padding="12,5"
                            Margin="2,0" Background="#FAFAFA" Cursor="Hand">
                        <TextBlock Name="BtnMapText"
                                   Text="Map"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="#18181B"/>
                    </Border>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Content Frame ──────────────────────────────── -->
        <Frame Name="MainFrame"
               Grid.Row="1"
               NavigationUIVisibility="Hidden"
               Background="#F4F4F5"/>
    </Grid>
</Window>
